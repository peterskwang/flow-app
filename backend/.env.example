# Wooverse Backend — Environment Variables
# Copy this file to .env and fill in values. Never commit .env.

# Server
PORT=8100
WS_PORT=8101
NODE_ENV=development

# Database — Wooverse isolated DB (do NOT use mochi_db or any other existing DB)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wooverse
DB_USER=wooverse_user
DB_PASS=CHANGEME

# JWT
JWT_SECRET=CHANGEME_LONG_RANDOM_STRING
JWT_EXPIRES_IN=30d

# Maps — Gaode (Amap)
GAODE_API_KEY=

# Admin
ADMIN_PASSWORD=CHANGEME

# Apple Sign In
APPLE_CLIENT_ID=com.wooverse.app
